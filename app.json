      "settings": [
        {
          "type": "group",
          "label": {
            "en": "Dexcom account",
            "de": "Dexcom-Konto",
            "nl": "Dexcom-account"
          },
          "children": [
            {
              "id": "username",
              "type": "text",
              "label": {
                "en": "Username",
                "de": "Benutzername",
                "nl": "Gebruikersnaam"
              },
              "hint": {
                "en": "Dexcom username, email, or phone number of the person wearing the sensor — the same login they use in the G6/G7 app.",
                "de": "Dexcom-Benutzername, E-Mail-Adresse oder Telefonnummer der Person, die den Sensor trägt — dieselben Zugangsdaten, die sie in der G6/G7-App verwendet.",
                "nl": "Dexcom-gebruikersnaam, e-mailadres of telefoonnummer van de persoon die de sensor draagt — dezelfde inloggegevens die in de G6/G7-app worden gebruikt."
              },
              "value": ""
            },
            {
              "id": "password",
              "type": "password",
              "label": {
                "en": "Password",
                "de": "Passwort",
                "nl": "Wachtwoord"
              },
              "hint": {
                "en": "Password for that same Dexcom account. Stored securely and only used to poll for glucose readings.",
                "de": "Passwort desselben Dexcom-Kontos. Wird sicher gespeichert und nur verwendet, um Glukosewerte abzurufen.",
                "nl": "Wachtwoord van datzelfde Dexcom-account. Wordt veilig opgeslagen en alleen gebruikt om glucosewaarden op te halen."
              },
              "value": ""
            },
            {
              "id": "region",
              "type": "dropdown",
              "label": {
                "en": "Region",
                "de": "Region",
                "nl": "Regio"
              },
              "hint": {
                "en": "Which Dexcom Share server this account uses. Must match the region the G6/G7 app was set up with.",
                "de": "Welchen Dexcom Share-Server dieses Konto verwendet. Muss mit der Region übereinstimmen, mit der die G6/G7-App eingerichtet wurde.",
                "nl": "Welke Dexcom Share-server dit account gebruikt. Moet overeenkomen met de regio waarmee de G6/G7-app is ingesteld."
              },
              "value": "us",
              "values": [
                {
                  "id": "us",
                  "label": {
                    "en": "United States",
                    "de": "Vereinigte Staaten",
                    "nl": "Verenigde Staten"
                  }
                },
                {
                  "id": "ous",
                  "label": {
                    "en": "Outside the US",
                    "de": "Außerhalb der USA",
                    "nl": "Buiten de VS"
                  }
                },
                {
                  "id": "jp",
                  "label": {
                    "en": "Japan",
                    "de": "Japan",
                    "nl": "Japan"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "group",
          "label": {
            "en": "Data and display",
            "de": "Daten und Anzeige",
            "nl": "Gegevens en weergave"
          },
          "children": [
            {
              "id": "units",
              "type": "dropdown",
              "label": {
                "en": "Glucose unit",
                "de": "Glukoseeinheit",
                "nl": "Glucose-eenheid"
              },
              "hint": {
                "en": "Unit for this device's glucose values: device tile, the dashboard widget, and flow cards. Alarm thresholds below convert automatically when you change this (unless you also edit them in the same save).",
                "de": "Einheit für die Glukosewerte dieses Geräts: Gerätekachel, Dashboard-Widget und Flow-Karten. Die Alarmschwellen unten werden automatisch umgerechnet, wenn Sie dies ändern (es sei denn, Sie bearbeiten sie im selben Speichervorgang ebenfalls).",
                "nl": "Eenheid voor de glucosewaarden van dit apparaat: apparaattegel, dashboardwidget en flowkaarten. De onderstaande alarmdrempels worden automatisch omgerekend wanneer u dit wijzigt (tenzij u ze in dezelfde opslagactie ook zelf aanpast)."
              },
              "value": "mgdl",
              "values": [
                {
                  "id": "mgdl",
                  "label": {
                    "en": "mg/dL",
                    "de": "mg/dL",
                    "nl": "mg/dL"
                  }
                },
                {
                  "id": "mmol",
                  "label": {
                    "en": "mmol/L",
                    "de": "mmol/L",
                    "nl": "mmol/L"
                  }
                }
              ]
            },
            {
              "id": "noDataTimeoutMin",
              "type": "number",
              "label": {
                "en": "No-data timeout (minutes)",
                "de": "Zeitüberschreitung ohne Daten (Minuten)",
                "nl": "Time-out zonder gegevens (minuten)"
              },
              "hint": {
                "en": "If no new reading arrives for this many minutes, the No Data alarm triggers. Dexcom sensors normally report roughly every 5 minutes, so a small multiple of that absorbs the occasional missed transmission.",
                "de": "Wenn innerhalb dieser Anzahl von Minuten kein neuer Messwert eintrifft, löst der Alarm „Keine Daten“ aus. Dexcom-Sensoren melden normalerweise etwa alle 5 Minuten, sodass ein kleines Vielfaches davon gelegentlich ausbleibende Übertragungen abfängt.",
                "nl": "Als er binnen dit aantal minuten geen nieuwe meting binnenkomt, wordt het alarm ‘geen gegevens’ geactiveerd. Dexcom-sensoren rapporteren normaal ongeveer elke 5 minuten, dus een klein veelvoud daarvan vangt incidentele gemiste overdrachten op."
              },
              "value": 20,
              "min": 10,
              "max": 120
            },
            {
              "id": "widgetChartScale",
              "type": "dropdown",
              "label": {
                "en": "Widget chart scale",
                "de": "Widget-Diagrammskala",
                "nl": "Widget-grafiekschaal"
              },
              "hint": {
                "en": "How the glucose history chart's vertical axis is scaled in the dashboard widget bound to this device. Normal always spans Dexcom's full 40–400 mg/dL (2.2–22.2 mmol/L) sensor range. Capped narrows the top to 300 mg/dL (~16.7 mmol/L) so day-to-day variation in the normal range is easier to read (readings above that pin to the top of the chart). Logarithmic keeps the full range but compresses the high end, giving the normal range more room without capping any reading.",
                "de": "Wie die vertikale Achse des Glukoseverlaufsdiagramms im diesem Gerät zugeordneten Dashboard-Widget skaliert wird. „Normal“ deckt immer den vollen Dexcom-Sensorbereich von 40–400 mg/dL (2,2–22,2 mmol/L) ab. „Begrenzt“ verkürzt die obere Grenze auf 300 mg/dL (~16,7 mmol/L), damit tägliche Schwankungen im Normalbereich besser erkennbar sind (Werte darüber werden oben an der Grenze fixiert). „Logarithmisch“ behält den vollen Bereich bei, staucht aber den oberen Teil, wodurch der Normalbereich mehr Platz erhält, ohne Messwerte zu kappen.",
                "nl": "Hoe de verticale as van de glucosegeschiedenisgrafiek in de aan dit apparaat gekoppelde dashboardwidget wordt geschaald. ‘Normaal’ beslaat altijd het volledige Dexcom-sensorbereik van 40–400 mg/dL (2,2–22,2 mmol/L). ‘Beperkt’ verkort de bovengrens tot 300 mg/dL (~16,7 mmol/L), zodat dagelijkse schommelingen in het normale bereik beter zichtbaar zijn (waarden daarboven blijven vastzitten aan de bovenrand). ‘Logaritmisch’ behoudt het volledige bereik maar drukt het hoge uiteinde samen, waardoor het normale bereik meer ruimte krijgt zonder metingen af te kappen."
              },
              "value": "normal",
              "values": [
                {
                  "id": "normal",
                  "label": {
                    "en": "Normal (40–400 mg/dL)",
                    "de": "Normal (40–400 mg/dL)",
                    "nl": "Normaal (40–400 mg/dL)"
                  }
                },
                {
                  "id": "capped",
                  "label": {
                    "en": "Capped at 300 mg/dL",
                    "de": "Begrenzt auf 300 mg/dL",
                    "nl": "Beperkt tot 300 mg/dL"
                  }
                },
                {
                  "id": "log",
                  "label": {
                    "en": "Logarithmic (40–400 mg/dL)",
                    "de": "Logarithmisch (40–400 mg/dL)",
                    "nl": "Logaritmisch (40–400 mg/dL)"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "group",
          "label": {
            "en": "Alarm thresholds",
            "de": "Alarmschwellen",
            "nl": "Alarmdrempels"
          },
          "children": [
