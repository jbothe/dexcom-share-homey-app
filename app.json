                "de": "Glukose bei oder unter diesem Wert löst den Alarm „Dringend niedrig“ aus. Wird in der oben gewählten Einheit eingegeben.",
                "nl": "Glucose op of onder deze waarde activeert het alarm ‘urgent laag’. Wordt ingevoerd in de hierboven gekozen eenheid."
              },
              "value": 55,
              "min": 0,
              "max": 400,
              "decimals": 1,
              "step": 0.1
            },
            {
              "id": "lowThreshold",
              "type": "number",
              "label": {
                "en": "Low",
                "de": "Niedrig",
                "nl": "Laag"
              },
              "hint": {
                "en": "Glucose at or below this value (and above Urgent Low) triggers the low alarm. Entered in the unit selected above.",
                "de": "Glukose bei oder unter diesem Wert (und über „Dringend niedrig“) löst den Alarm „Niedrig“ aus. Wird in der oben gewählten Einheit eingegeben.",
                "nl": "Glucose op of onder deze waarde (en boven ‘urgent laag’) activeert het alarm ‘laag’. Wordt ingevoerd in de hierboven gekozen eenheid."
              },
              "value": 70,
              "min": 0,
              "max": 400,
              "decimals": 1,
              "step": 0.1
            },
            {
              "id": "highThreshold",
              "type": "number",
              "label": {
                "en": "High",
                "de": "Hoch",
                "nl": "Hoog"
              },
              "hint": {
                "en": "Glucose at or above this value triggers the high alarm. Entered in the unit selected above.",
                "de": "Glukose bei oder über diesem Wert löst den Alarm „Hoch“ aus. Wird in der oben gewählten Einheit eingegeben.",
                "nl": "Glucose op of boven deze waarde activeert het alarm ‘hoog’. Wordt ingevoerd in de hierboven gekozen eenheid."
              },
              "value": 180,
              "min": 0,
              "max": 400,
              "decimals": 1,
              "step": 0.1
            }
          ]
